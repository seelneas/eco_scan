# 🌿 EcoScan Backend Configuration (Phase 7)
# ==========================================

# 1. Gemini AI API Key (REQUIRED)
# Generate one at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash-lite

# 2. External Sustainability Data (Optional)
# Get a key at https://wikirate.org (Profile -> Accounts)
WIKIRATE_API_KEY=""

# 3. Database (Phase 6 Caching & Brands)
# Default is local SQLite for easy development
DATABASE_URL=sqlite:///./ecoscan.db

# 4. Security & Rate Limiting (Phase 7)
# API_KEYS: A JSON list of valid keys, e.g., ["key1", "key2"].
# IMPORTANT: To disable API Key enforcement (Open Access), set to an empty string: API_KEYS=""
API_KEYS=""

# RATE_LIMIT_WINDOW: Window size in seconds (default: 60)
# RATE_LIMIT_ANALYZE: Max analysis requests (batch/stream) per window
# RATE_LIMIT_GENERAL: Max general requests (health/feedback/brands) per window
RATE_LIMIT_ANALYZE=30
RATE_LIMIT_GENERAL=120
RATE_LIMIT_WINDOW=60

# 4. Networking
CORS_ORIGINS=*
ENVIRONMENT=development

