{
    "manifest_version": 3,
    "name": "EcoScan – Sustainability Intelligence",
    "version": "0.1.0",
    "description": "AI-powered sustainability scoring and greenwashing detection for online shopping.",
    "permissions": [
        "activeTab",
        "storage",
        "sidePanel"
    ],
    "host_permissions": [
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.walmart.com/*",
        "https://www.patagonia.com/*",
        "https://www2.hm.com/*",
        "https://www.zara.com/*",
        "https://www.target.com/*",
        "https://www.etsy.com/*",
        "https://www.nordstrom.com/*"
    ],
    "background": {
        "service_worker": "src/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.amazon.com/*",
                "https://www.amazon.co.uk/*",
                "https://www.walmart.com/*",
                "https://www.patagonia.com/*",
                "https://www2.hm.com/*",
                "https://www.zara.com/*",
                "https://www.target.com/*",
                "https://www.etsy.com/*",
                "https://www.nordstrom.com/*"
            ],
            "js": [
                "src/contentScript.js"
            ],
            "css": [
                "styles/content.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}